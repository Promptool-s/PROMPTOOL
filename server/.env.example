# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
# Orígenes permitidos para CORS, separados por coma
CORS_ORIGINS=http://localhost:5173,https://promptool.app,https://www.promptool.app

# ── Base de datos (Supabase Postgres) ────────────────────────────────────────
# Supabase Dashboard → Project Settings → Database → Connection string (URI).
# Usar el "Session pooler" para serverless/PaaS. NUNCA la anon key acá.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── Auth (verificación de JWT emitidos por Supabase Auth) ────────────────────
# Supabase Dashboard → Project Settings → API → JWT Secret (legacy HS256).
# El frontend sigue logueándose con supabase.auth; este backend solo VERIFICA
# el access token que el frontend manda en Authorization: Bearer <token>.
SUPABASE_JWT_SECRET=tu-jwt-secret-de-supabase

# ── Proveedores de IA (SIN prefijo VITE_ — nunca llegan al navegador) ────────
GROQ_API_KEY=gsk_...
# Opcional: solo cuando se migre la generación de desafíos (fase 2)
GEMINI_API_KEY=

# ── Email (Mailtrap) ─────────────────────────────────────────────────────────
# El dominio está registrado en Mailtrap Sending.
# Token de la API de envío:
#   Mailtrap → Sending Domains → (tu dominio) → pestaña "API / SMTP" →
#   "API Tokens" → copiá el token. (Alternativa: Settings → API Tokens.)
MAILTRAP_API_TOKEN=tu-mailtrap-api-token
# Endpoint de envío. Dejalo así para PRODUCCIÓN.
#   Para probar sin mandar mails reales, usá el inbox de testing:
#   https://sandbox.api.mailtrap.io/api/send/<INBOX_ID>
#   (Mailtrap → Email Testing → tu inbox → Integrations → API → tomá el inbox_id de la URL)
MAILTRAP_API_URL=https://send.api.mailtrap.io/api/send
# Remitente. Debe ser una dirección del dominio verificado en Mailtrap
# (Sending Domains → tu dominio → estado "Verified").
MAIL_FROM_EMAIL=support@promptool.app
MAIL_FROM_NAME=PrompTool
# Secreto para firmar los tokens OTP (HMAC-SHA256). Cadena aleatoria larga,
# generala con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OTP_SECRET=cambia-esto-por-una-cadena-aleatoria-larga
# Base pública del sitio, para armar las URLs de los emails de Auth.
APP_BASE_URL=https://promptool.app
# Opcional: secreto compartido con el Auth Hook de Supabase.
#   Supabase → Authentication → Hooks → "Send Email Hook" (HTTP) → header
#   Authorization: Bearer <este valor>. Dejalo vacío si no usás el hook.
SUPABASE_AUTH_HOOK_SECRET=

# ── Storage server-side (avatares / imágenes de desafíos) — OPCIONALES ───────
# Si faltan, los endpoints de upload responden 503 pero el resto funciona.
# Supabase Dashboard → Project Settings → API → "Project URL"
SUPABASE_URL=
# Supabase Dashboard → Project Settings → API → "service_role" key.
# ⚠️ SECRETA: saltea RLS. Solo en el servidor, JAMÁS con prefijo VITE_.
SUPABASE_SERVICE_ROLE_KEY=
